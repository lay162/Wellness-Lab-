# Project URL from Supabase → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
# Publishable key (sb_publishable_...) or legacy anon key (eyJ...)
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key-here

# Local development only — skip login (never set true in production)
VITE_DEV_BYPASS_AUTH=false

# Scripts only — provision-shop-admin.mjs (never commit; remove after use)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-from-supabase-dashboard
