{
  "redirects": [
    { "source": "/BusinessCard", "destination": "/businesscard", "permanent": true },
    { "source": "/BusinessCard/", "destination": "/businesscard", "permanent": true },
    { "source": "/BusinessCard/index.html", "destination": "/businesscard", "permanent": true },
    { "source": "/card", "destination": "/businesscard", "permanent": true },
    { "source": "/card/", "destination": "/businesscard", "permanent": true },
    { "source": "/businesscard/index.html", "destination": "/businesscard", "permanent": true }
  ],
  "rewrites": [
    { "source": "/businesscard", "destination": "/businesscard/index.html" },
    { "source": "/((?!assets|icons|favicon|app-icon|logo|og-image|offline|sw|workbox|manifest|robots\\.txt|sitemap\\.xml|businesscard).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
